# Database Connection (Turso LibSQL, Supabase Postgres, or Local SQLite)
DATABASE_URL="file:./dev.db"

# NextAuth / Auth.js Production Configuration
NEXTAUTH_SECRET="your-production-secret-key-at-least-32-chars"
NEXTAUTH_URL="https://yourdomain.et"
AUTH_SECRET="your-production-secret-key-at-least-32-chars"
AUTH_URL="https://yourdomain.et"

# Resend API Key for Email Notifications
RESEND_API_KEY="re_..."

# Cloudinary Storage Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="horizon_uploads"

# Zoom Server-to-Server OAuth Credentials
ZOOM_CLIENT_ID="your-zoom-client-id"
ZOOM_CLIENT_SECRET="your-zoom-client-secret"
ZOOM_ACCOUNT_ID="your-zoom-account-id"

# Chapa Payment Gateway Configuration
CHAPA_SECRET_KEY="CHASECK-..."
NEXT_PUBLIC_CHAPA_PUBLIC_KEY="CHAPUBK-..."
CHAPA_WEBHOOK_SECRET="your-chapa-webhook-secret"
